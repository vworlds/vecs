{
  "compilerOptions": {
    "strict": true,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "sourceMap": true,
    "baseUrl": ".",
    "paths": {
      "@vworlds/vecs": ["lib/vecs/src/index.ts"],
      "@vworlds/vecs-client": ["lib/vecs-client/src/index.ts"],
      "@vworlds/vecs-protocol": ["lib/vecs-protocol/src/index.ts"],
      "@vworlds/vecs-server": ["lib/vecs-server/src/index.ts"],
      "@vworlds/vecs-wire": ["lib/vecs-wire/src/index.ts"]
    },
    "target": "ES2020",
    "moduleResolution": "Node16",
    "module": "Node16",
    "noImplicitOverride": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "stripInternal": true,
    "noEmit": true
  }
}
